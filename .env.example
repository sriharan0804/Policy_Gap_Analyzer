PGA_APP_ENV=development
PGA_DEBUG=false
PGA_LOG_LEVEL=INFO

PGA_DATA_DIRECTORY=data
PGA_REGULATION_DIRECTORY=data/regulations
PGA_POLICY_DIRECTORY=data/policies
PGA_PROCESSED_DIRECTORY=data/processed
PGA_FAISS_DIRECTORY=data/faiss

PGA_MAX_UPLOAD_SIZE_MB=25
PGA_RETRIEVAL_TOP_K=5
PGA_MINIMUM_RETRIEVAL_SCORE=0.30

PGA_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

PGA_LLM_PROVIDER=disabled
PGA_OPENAI_API_KEY=
PGA_GROQ_API_KEY=